#!/bin/bash
# Pre-commit hook: run pytest on backend test changes
# Install: git config core.hooksPath .githooks

# Resolve repo root (hooks may run from different CWDs)
REPO_ROOT=$(git rev-parse --show-toplevel)

# Check if any backend files are staged
BACKEND_CHANGED=$(git diff --cached --name-only -- 'backend/' | head -1)

if [ -z "$BACKEND_CHANGED" ]; then
    exit 0
fi

echo "[pre-commit] Backend files changed -- running pytest..."

# Find the right Python executable (use absolute paths)
if [ -f "$REPO_ROOT/backend/venv/Scripts/python.exe" ]; then
    PYTHON="$REPO_ROOT/backend/venv/Scripts/python.exe"
elif [ -f "$REPO_ROOT/backend/venv/bin/python" ]; then
    PYTHON="$REPO_ROOT/backend/venv/bin/python"
else
    PYTHON="python"
fi

# Run tests (skip if pytest not installed)
if "$PYTHON" -c "import pytest" 2>/dev/null; then
    cd "$REPO_ROOT/backend"
    OUTPUT=$("$PYTHON" -m pytest tests/ --ignore=tests/scripts -x -q --tb=short 2>&1)
    RESULT=$?
    cd "$REPO_ROOT"

    if [ $RESULT -ne 0 ]; then
        # Check if ALL failures are DB connection errors (no local PG)
        DB_ERRORS=$(echo "$OUTPUT" | grep -c "OperationalError\|connection refused\|could not connect\|pg8000\|No module named" || true)
        if [ "$DB_ERRORS" -gt 0 ]; then
            echo "[pre-commit] Failures are environment errors (no local PG or missing deps)."
            echo "[pre-commit] CI will run full tests. Allowing commit."
            exit 0
        fi
        echo "$OUTPUT" | tail -20
        echo ""
        echo "[pre-commit] Tests FAILED (non-environment errors). Commit blocked."
        exit 1
    fi
    echo "[pre-commit] Tests passed."
else
    echo "[pre-commit] pytest not installed -- skipping (CI will verify)."
fi

# Privacy scan: check staged files for personal identifiers
STAGED_CONTENT=$(git diff --cached --diff-filter=ACM -U0 2>/dev/null)

PRIVACY_ISSUES=0

# Check for home directory paths (Windows and Unix)
if echo "$STAGED_CONTENT" | grep -qiE "(C:\\\\Users\\\\[a-zA-Z]|/home/[a-zA-Z]|/Users/[a-zA-Z])" 2>/dev/null; then
    # Allow paths in .githooks, .claude, CLAUDE.md, and config files
    REAL_PATH_FILES=$(echo "$STAGED_CONTENT" | grep -E "^\+\+\+ b/" | grep -v ".githooks\|.claude\|CLAUDE.md\|.local\|.gitignore" | head -5)
    if [ -n "$REAL_PATH_FILES" ]; then
        echo "[pre-commit] WARNING: Possible personal paths in staged files:"
        echo "$REAL_PATH_FILES" | sed 's/^+++ b\//  /'
        PRIVACY_ISSUES=1
    fi
fi

# Check for hardcoded API keys/tokens (common patterns)
if echo "$STAGED_CONTENT" | grep -qE "^\\+(.*)(sk-[a-zA-Z0-9]{20,}|sk-ant-[a-zA-Z0-9]{20,}|sk-proj-[a-zA-Z0-9]{20,}|ghp_[a-zA-Z0-9]{36}|AKIA[0-9A-Z]{16})" 2>/dev/null; then
    echo "[pre-commit] BLOCKED: Possible API key/token in staged changes."
    echo "[pre-commit] Use environment variables or Proton Pass instead."
    exit 1
fi

if [ $PRIVACY_ISSUES -ne 0 ]; then
    echo "[pre-commit] Privacy warnings above -- review before pushing to public repo."
fi

exit 0
